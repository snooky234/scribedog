{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$RESOURCE/**" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "https://api.openai.com/*" },
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://api.mistral.ai/*" }
      ]
    },
    "fs:read-dirs",
    "fs:read-files",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat"
  ]
}
